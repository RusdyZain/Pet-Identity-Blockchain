{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "chain:compile": "hardhat compile",
    "chain:test": "hardhat test",
    "test:contract": "npm run chain:test",
    "test:integration:api": "vitest run tests/integration/api.flow.test.ts",
    "test:integration:auth": "vitest run tests/integration/walletAuthChallenge.test.ts",
    "test:integration": "vitest run tests/integration",
    "test": "npm run chain:test && npm run test:integration",
    "deploy:localhost": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:goerli": "hardhat run scripts/deploy.js --network goerli",
    "deploy:ganache": "hardhat run scripts/deploy.js --network ganache",
    "deploy:besu": "hardhat run scripts/deploy.js --network besuClique"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.23"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^7.2.0",
    "hardhat": "^2.27.0",
    "prisma": "^7.4.2",
    "sql.js": "^1.14.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
