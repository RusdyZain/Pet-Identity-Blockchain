{
  "defaultProfile": "baseline",
  "profiles": {
    "baseline": {
      "description": "Ramp-up, steady-state, lalu ramp-down untuk campuran read/write/auth.",
      "scenarios": {
        "read_heavy": {
          "executor": "ramping-arrival-rate",
          "exec": "readHeavyTraffic",
          "startRate": 5,
          "timeUnit": "1s",
          "preAllocatedVUs": 20,
          "maxVUs": 80,
          "stages": [
            { "target": 20, "duration": "2m" },
            { "target": 20, "duration": "10m" },
            { "target": 0, "duration": "2m" }
          ],
          "tags": { "flow": "read-heavy" }
        },
        "write_heavy": {
          "executor": "ramping-vus",
          "exec": "writeHeavyBlockchain",
          "startVUs": 1,
          "stages": [
            { "target": 4, "duration": "2m" },
            { "target": 4, "duration": "8m" },
            { "target": 0, "duration": "2m" }
          ],
          "startTime": "30s",
          "gracefulRampDown": "30s",
          "tags": { "flow": "write-heavy" },
          "walletNeeds": { "OWNER": 1, "CLINIC": 1 }
        },
        "auth_burst": {
          "executor": "constant-arrival-rate",
          "exec": "authBurst",
          "rate": 8,
          "timeUnit": "1s",
          "duration": "6m",
          "preAllocatedVUs": 12,
          "maxVUs": 40,
          "startTime": "15s",
          "tags": { "flow": "auth-burst" }
        },
        "trace_notification": {
          "executor": "constant-vus",
          "exec": "traceNotificationFlow",
          "vus": 3,
          "duration": "8m",
          "startTime": "45s",
          "tags": { "flow": "trace-notification" }
        },
        "correction_transfer": {
          "executor": "constant-vus",
          "exec": "correctionTransferFlow",
          "vus": 1,
          "duration": "6m",
          "startTime": "90s",
          "tags": { "flow": "correction-transfer" },
          "walletNeeds": { "OWNER": 2, "CLINIC": 1 }
        }
      }
    },
    "spike": {
      "description": "Lonjakan traffic mendadak untuk memvalidasi burst handling.",
      "scenarios": {
        "read_heavy_spike": {
          "executor": "ramping-arrival-rate",
          "exec": "readHeavyTraffic",
          "startRate": 10,
          "timeUnit": "1s",
          "preAllocatedVUs": 40,
          "maxVUs": 180,
          "stages": [
            { "target": 15, "duration": "1m" },
            { "target": 120, "duration": "30s" },
            { "target": 15, "duration": "2m" },
            { "target": 0, "duration": "30s" }
          ],
          "tags": { "flow": "read-heavy" }
        },
        "auth_burst_spike": {
          "executor": "ramping-arrival-rate",
          "exec": "authBurst",
          "startRate": 10,
          "timeUnit": "1s",
          "preAllocatedVUs": 20,
          "maxVUs": 120,
          "startTime": "20s",
          "stages": [
            { "target": 80, "duration": "20s" },
            { "target": 10, "duration": "1m" },
            { "target": 0, "duration": "20s" }
          ],
          "tags": { "flow": "auth-burst" }
        },
        "write_heavy_spike": {
          "executor": "constant-vus",
          "exec": "writeHeavyBlockchain",
          "vus": 4,
          "duration": "4m",
          "startTime": "30s",
          "tags": { "flow": "write-heavy" },
          "walletNeeds": { "OWNER": 1, "CLINIC": 1 }
        },
        "correction_transfer_spike": {
          "executor": "constant-vus",
          "exec": "correctionTransferFlow",
          "vus": 1,
          "duration": "4m",
          "startTime": "1m",
          "tags": { "flow": "correction-transfer" },
          "walletNeeds": { "OWNER": 2, "CLINIC": 1 }
        }
      }
    },
    "stress": {
      "description": "Naikkan beban sampai mendekati kapasitas limit sistem.",
