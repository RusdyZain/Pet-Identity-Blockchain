        "auth_burst_stress": {
          "executor": "constant-arrival-rate",
          "exec": "authBurst",
          "rate": 20,
          "timeUnit": "1s",
          "duration": "8m",
          "preAllocatedVUs": 40,
          "maxVUs": 200,
          "startTime": "30s",
          "tags": { "flow": "auth-burst" }
        },
        "correction_transfer_stress": {
          "executor": "constant-vus",
          "exec": "correctionTransferFlow",
          "vus": 2,
          "duration": "8m",
          "startTime": "2m",
          "tags": { "flow": "correction-transfer" },
          "walletNeeds": { "OWNER": 2, "CLINIC": 1 }
        }
      }
    },
    "soak": {
      "description": "Uji ketahanan jangka panjang untuk memory leak, queue growth, dan degradasi throughput.",
