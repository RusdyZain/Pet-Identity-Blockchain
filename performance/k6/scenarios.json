  },
  "thresholds": {
    "checks": ["rate>0.97"],
    "http_req_failed": ["rate<0.02"],
    "http_req_duration": ["p(95)<2500", "p(99)<5000"],
    "http_req_duration{flow:read-heavy}": ["p(95)<1200"],
    "http_req_duration{flow:auth-burst}": ["p(95)<1500"],
    "http_req_duration{flow:write-heavy}": ["p(95)<5000"],
    "http_reqs": ["rate>5"],
    "rpc_error_rate": ["rate<0.02"],
    "tx_submit_ms": ["p(95)<4000"],
    "tx_confirm_ms": ["p(95)<120000"],
    "end_to_end_flow_latency": ["p(95)<180000"],
    "end_to_end_flow_latency{flow:read-heavy}": ["p(95)<5000"],
    "end_to_end_flow_latency{flow:auth-burst}": ["p(95)<4000"],
    "flow_success_rate": ["rate>0.95"]
  }
}
