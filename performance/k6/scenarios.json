          "exec": "readHeavyTraffic",
          "rate": 15,
          "timeUnit": "1s",
          "duration": "2h",
          "preAllocatedVUs": 40,
          "maxVUs": 160,
          "tags": { "flow": "read-heavy" }
        },
        "write_heavy_soak": {
          "executor": "constant-vus",
          "exec": "writeHeavyBlockchain",
          "vus": 4,
          "duration": "2h",
          "startTime": "1m",
          "tags": { "flow": "write-heavy" },
          "walletNeeds": { "OWNER": 1, "CLINIC": 1 }
        },
        "auth_burst_soak": {
          "executor": "constant-arrival-rate",
          "exec": "authBurst",
          "rate": 3,
          "timeUnit": "1s",
          "duration": "2h",
          "startTime": "2m",
          "preAllocatedVUs": 15,
          "maxVUs": 80,
          "tags": { "flow": "auth-burst" }
        },
        "trace_notification_soak": {
          "executor": "constant-vus",
          "exec": "traceNotificationFlow",
          "vus": 4,
          "duration": "2h",
          "startTime": "90s",
          "tags": { "flow": "trace-notification" }
        },
        "correction_transfer_soak": {
          "executor": "constant-vus",
          "exec": "correctionTransferFlow",
          "vus": 1,
          "duration": "1h",
          "startTime": "30m",
          "tags": { "flow": "correction-transfer" },
          "walletNeeds": { "OWNER": 2, "CLINIC": 1 }
        }
      }
    },
    "ci": {
      "description": "Profil singkat untuk pipeline CI (cepat, tetap validasi flow utama).",
      "scenarios": {
        "read_heavy_ci": {
          "executor": "ramping-arrival-rate",
          "exec": "readHeavyTraffic",
          "startRate": 2,
          "timeUnit": "1s",
          "preAllocatedVUs": 6,
          "maxVUs": 20,
          "stages": [
            { "target": 5, "duration": "30s" },
            { "target": 5, "duration": "60s" },
            { "target": 0, "duration": "15s" }
          ],
          "tags": { "flow": "read-heavy" }
        },
        "write_heavy_ci": {
          "executor": "ramping-vus",
          "exec": "writeHeavyBlockchain",
          "startVUs": 1,
          "stages": [
            { "target": 2, "duration": "30s" },
            { "target": 2, "duration": "60s" },
            { "target": 0, "duration": "15s" }
          ],
          "startTime": "10s",
          "tags": { "flow": "write-heavy" },
          "walletNeeds": { "OWNER": 1, "CLINIC": 1 }
