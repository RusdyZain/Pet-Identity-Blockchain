          "startRate": 10,
          "timeUnit": "1s",
          "preAllocatedVUs": 60,
          "maxVUs": 240,
          "stages": [
            { "target": 20, "duration": "2m" },
            { "target": 40, "duration": "3m" },
            { "target": 80, "duration": "3m" },
            { "target": 120, "duration": "3m" },
            { "target": 0, "duration": "2m" }
